# =============================================================================
# TealTiger Playground - Environment Variables
# =============================================================================
# Copy this file to .env.local for local development.
# For Vercel deployment, set these in the Vercel project dashboard:
#   Settings > Environment Variables
# =============================================================================

# Supabase Configuration (Required)
# Get these values from your Supabase project dashboard: https://supabase.com/dashboard
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Note: VITE_ prefix is required for Vite to expose variables to the client bundle.
# Never expose service_role keys or secrets via VITE_ variables.
