    "jspdf": "^4.2.1",
    "lucide-react": "^0.294.0",
    "lz-string": "^1.5.0",
    "monaco-editor": "^0.45.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.13.1",
    "reactflow": "^11.11.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.13.0",
    "@playwright/test": "^1.40.1",
