    "build:size": "npm run build && node scripts/check-bundle-size.mjs",
    "docs:api": "typedoc"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@supabase/supabase-js": "^2.99.1",
    "clsx": "^2.0.0",
