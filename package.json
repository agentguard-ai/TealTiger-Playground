    "@types/node": "^24.12.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^1.0.4",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "fast-check": "^3.15.0",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "typedoc": "^0.25.13",
    "typescript-eslint": "^8.56.1",
